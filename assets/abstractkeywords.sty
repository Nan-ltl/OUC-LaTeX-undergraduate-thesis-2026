\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{assets/abstractkeywords}[2015/05/20 Abstract and Keyword Page]

%% Require cnabstract, cnkeyword, enabstract, enkeywords.

\RequirePackage{abstract}
\RequirePackage{fontspec}
\RequirePackage{ctex}
\setCJKfamilyfont{zhsong}{simsun.ttf}[AutoFakeBold]
\renewcommand{\songti}{\CJKfamily{zhsong}}
\setCJKfamilyfont{myhei}{SimHei}[AutoFakeBold]
\renewcommand{\heiti}{\fontspec{SimHei}}

\long\def\cnabstractkeywords#1#2{
	\def\@cnabstract{#1}
	\def\@cnkeywords{#2}
}

\long\def\enabstractkeywords#1#2{
	\def\@enabstract{#1}
	\def\@enkeywords{#2}
}

\newcommand{\fixbaselineskip}{%
	\setlength{\baselineskip}{24pt}%
	\setlength{\lineskip}{0pt}%
	\setlength{\lineskiplimit}{0pt}%
}

\newcommand*{\makeabstract}{
	\newpage
	\pagenumbering{Roman}
	\addcontentsline{toc}{nonumbersection}{\zihao{4}\songti{摘要}}
	{\centering
		\zihao{3}\fixbaselineskip\heiti{\@title} \par
		\heiti{摘\ \ \ 要}\par}
	
	
	\ifdefined\@cnabstract
	\zihao{-4}\fixbaselineskip\songti\@cnabstract\par
	\zihao{-4}\fixbaselineskip\heiti 关键词：\textbf{\@cnkeywords} 
	\newpage
	\fi
	\addcontentsline{toc}{nonumbersection}{\zihao{4}\songti{Abstract}}
	\ifdefined\@enabstract
	{\centering
		\zihao{3}\fixbaselineskip\heiti{\@entitle\par
			Abstract\par}}
	
	\renewcommand\abstractname{\zihao{3}\fixbaselineskip\heiti{Abstract}}
	
	\zihao{4}\fixbaselineskip\setmainfont{Times New Roman}\@enabstract\par
	
	\zihao{4}\fixbaselineskip\setmainfont{Times New Roman}\textbf{Keywords:\@enkeywords} 
	
	\fi
	\newpage
}